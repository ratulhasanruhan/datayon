# Copy to `.env.local` — never commit real keys.

NEXT_PUBLIC_SITE_URL=https://datayon.bd

# Optional — Google Search Console → Settings → Ownership → HTML tag (content value only)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

NEXT_PUBLIC_APPWRITE_ENDPOINT=https://nyc.cloud.appwrite.io/v1
# Appwrite Console → Your project → Settings → Project ID
NEXT_PUBLIC_APPWRITE_PROJECT_ID=

# Storage bucket for article cover images (default: article-covers). Create via seed or Console.
NEXT_PUBLIC_APPWRITE_BUCKET_COVERS=article-covers

# Full-issue PDF + exported cover PNG (default: magazine-assets). Seed creates bucket; upload via npm run magazine:upload
NEXT_PUBLIC_APPWRITE_BUCKET_MAGAZINE=magazine-assets

# Console → API Keys → scopes: Databases + Storage (server only)
APPWRITE_API_KEY=

# Optional: development key from Console (local tooling only; not NEXT_PUBLIC)
APPWRITE_DEV_KEY=

# Article JSON API lives on datayon-pcard (GET /api/articles). Add Appwrite keys there, not only here.
